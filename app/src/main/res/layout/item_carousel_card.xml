<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="180dp"
    android:layout_marginEnd="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/verde">

        <ImageView
            android:id="@+id/ivCardBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_card_overlay" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipCardTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="Nova vaga"
            android:textSize="11sp"
            android:textColor="@color/textoescuro"
            app:chipBackgroundColor="@color/bege"
            app:chipStrokeWidth="0dp"
            app:chipMinHeight="28dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvCardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desenvolvedor Android"
                android:textSize="16sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/bege"
                android:textStyle="bold"
                xmlns:tools="http://schemas.android.com/tools"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvCardSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Empresa XYZ · Remoto"
                android:textSize="12sp"
                android:textColor="@color/brancobege"
                xmlns:tools="http://schemas.android.com/tools"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>